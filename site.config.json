{
  "site": {
    "title": "plain \u2014 sample site",
    "url": "https://plain-cms.com",
    "repo": "plain-cms/plain",
    "oauthUrl": "https://plain-oauth.victorantos.workers.dev",
    "description": "The sample site that ships with plain, the Git-native CMS.",
    "language": "en",
    "theme": "default"
  },
  "collections": {
    "pages": {
      "path": "content/pages",
      "urlPattern": "/:slug/",
      "template": "page",
      "fields": [
        {
          "name": "title",
          "type": "text",
          "required": true
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "draft",
          "type": "boolean",
          "default": false
        }
      ]
    },
    "posts": {
      "path": "content/posts",
      "urlPattern": "/blog/:slug/",
      "template": "post",
      "listUrl": "/blog/",
      "listTemplate": "list",
      "label": "Blog",
      "sortBy": "date",
      "sortOrder": "desc",
      "rss": true,
      "fields": [
        {
          "name": "title",
          "type": "text",
          "required": true
        },
        {
          "name": "date",
          "type": "date",
          "required": true
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "cover",
          "type": "image"
        },
        {
          "name": "tags",
          "type": "list"
        },
        {
          "name": "draft",
          "type": "boolean",
          "default": false
        }
      ]
    }
  },
  "plugins": [
    "search",
    "reading-time"
  ]
}
